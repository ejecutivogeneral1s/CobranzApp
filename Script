  }
}

// --- MOTOR DE CÁLCULO DE FECHAS OFICIALES ---
function obtenerDiasFestivos(anio) {
  var dias = [];

  // 1. Año Nuevo (Fijo)
  dias.push({fecha: new Date(anio, 0, 1), motivo: 'Año Nuevo', tipo: 'Fijo'});

  // 2. Día de la Constitución (Móvil: Primer lunes de febrero)
  // Nota: en JavaScript los meses van de 0 (Enero) a 11 (Diciembre)
  dias.push({fecha: calcularLunesMovil(anio, 1, 1), motivo: 'Día de la Constitución', tipo: 'Móvil'});

  // 3. Natalicio de Benito Juárez (Móvil: Tercer lunes de marzo)
  dias.push({fecha: calcularLunesMovil(anio, 2, 3), motivo: 'Natalicio de Benito Juárez', tipo: 'Móvil'});

  // 4. Día del Trabajo (Fijo)
  dias.push({fecha: new Date(anio, 4, 1), motivo: 'Día del Trabajo', tipo: 'Fijo'});

  // 5. Día de la Independencia (Fijo)
  dias.push({fecha: new Date(anio, 8, 16), motivo: 'Día de la Independencia', tipo: 'Fijo'});

  // 6. Transmisión del Poder Ejecutivo (1 de octubre - Aplica cada 6 años, iniciado en 2024)
  if ((anio - 2024) % 6 === 0) {
    dias.push({fecha: new Date(anio, 9, 1), motivo: 'Transmisión Poder Ejecutivo', tipo: 'Fijo cada 6 años'});
  }

  // 7. Revolución Mexicana (Móvil: Tercer lunes de noviembre)
  dias.push({fecha: calcularLunesMovil(anio, 10, 3), motivo: 'Revolución Mexicana', tipo: 'Móvil'});

  // 8. Navidad (Fijo)
  dias.push({fecha: new Date(anio, 11, 25), motivo: 'Navidad', tipo: 'Fijo'});

  return dias;
}

// --- FUNCIÓN MATEMÁTICA PARA ENCONTRAR LOS PUENTES ---
function calcularLunesMovil(anio, mes, numeroDeLunes) {
  var fecha = new Date(anio, mes, 1);
  var diaSemana = fecha.getDay(); // 0 es Domingo, 1 es Lunes
  
  // Calculamos cuántos días faltan para el primer lunes
  var diasParaPrimerLunes = (diaSemana === 0) ? 1 : (diaSemana === 1) ? 0 : 8 - diaSemana;
  
  // Le sumamos las semanas necesarias (ej. para el 3er lunes, sumamos 14 días)
  fecha.setDate(1 + diasParaPrimerLunes + (numeroDeLunes - 1) * 7);
  return fecha;
}

// --- ACTIVADOR AUTOMÁTICO (TRIGGER) ---
function programarActualizadorAnual() {
  // Primero eliminamos cualquier activador previo para no tener duplicados
  var triggers = ScriptApp.getProjectTriggers();
  for (var i = 0; i < triggers.length; i++) {
    if (triggers[i].getHandlerFunction() === 'actualizarFestivosMexico') {
      ScriptApp.deleteTrigger(triggers[i]);
    }
  }

  // Creamos un activador que corra el 1 de enero de cada año a las 2:00 AM
  ScriptApp.newTrigger('actualizarFestivosMexico')
    .timeBased()
    .onMonthDay(1)
    .atHour(2)
    .create();
}


