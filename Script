          for (let i = 1; i < xlsxData.length; i++) {
            let filaXLSX = xlsxData[i];
            let reciboIdActual = String(filaXLSX[indexReciboIdXLSX]).trim();

            if (reciboIdActual !== "") {
              
              // ✨ ATRAPAMOS EL ID Y CALCULAMOS EL RANGO DE FECHAS
              recibosEntrantesSet.add(reciboIdActual);
              if (indexVigenciaXLSX !== -1) {
                let fechaXLSX = new Date(filaXLSX[indexVigenciaXLSX]);
                if (!isNaN(fechaXLSX.getTime())) {
                  if (!minFechaReporte || fechaXLSX < minFechaReporte) minFechaReporte = fechaXLSX;
                  if (!maxFechaReporte || fechaXLSX > maxFechaReporte) maxFechaReporte = fechaXLSX;
                }
              }
              
              // ✨ TRAMPA LÓGICA: Extracción anticipada del vendedor para auditar claves
              let tempIndexVend = cabecerasXLSX.indexOf('Vendedor');
              let tempIndexClave = cabecerasXLSX.indexOf('Clave de Agente');
              let nombreVendCrudo = tempIndexVend !== -1 ? String(filaXLSX[tempIndexVend]).trim() : "";
              let nombreVendLimpio = nombreVendCrudo.replace(/^\(D\)\s*/i, "").trim();
              let grupoDelVendedor = mapaVendedoresGrupo.has(nombreVendLimpio) ? String(mapaVendedoresGrupo.get(nombreVendLimpio)).toLowerCase() : "";

              // Si es de 1seguros, validamos su clave estandarizada
              if (grupoDelVendedor.includes("1seguros")) {
                let claveExtraida = tempIndexClave !== -1 ? String(filaXLSX[tempIndexClave]).trim() : "";
                if (claveExtraida !== "") {
                  let claveComparar = claveExtraida.replace(/^0+/, '') || "0";
                  if (!clavesPermitidasJMV.has(claveComparar)) {
                    clavesHuerfanasJMV.add(`${claveExtraida} (${nombreVendLimpio})`);
                  }
                }
              }

              let nuevaFila = cabecerasMaestras.map(cabecera => {
                if (cabecera === 'Estado_Cobranza' || cabecera === 'Ultima_Gestion' || cabecera === 'Notas_Asistente') return null;

                // INYECCIÓN DE GRUPO LÍMPIO (Reutilizando la variable extraída arriba)
                if (cabecera === 'Grupo') {
                  return mapaVendedoresGrupo.has(nombreVendLimpio) ? mapaVendedoresGrupo.get(nombreVendLimpio) : "";
                }
                
                let indexXLSX = cabecerasXLSX.indexOf(cabecera);
                if (indexXLSX === -1) return ''; 
                
                let valorOriginal = filaXLSX[indexXLSX];
                
                if (cabecera === 'Ramo' && valorOriginal) ramosProcesadosSet.add(String(valorOriginal).trim());
                if (cabecera === 'Vendedor' && valorOriginal) vendedoresProcesadosSet.add(String(valorOriginal).trim());

                let nombreCol = cabecera.toLowerCase();
                if ((nombreCol.includes('fecha') || nombreCol.includes('vigencia') || nombreCol.includes('vencimiento')) && !nombreCol.includes('dias')) {
                  if (valorOriginal === '' || valorOriginal === null) return '';
                  if (valorOriginal instanceof Date) return valorOriginal; 
                  let intentoFecha = new Date(valorOriginal);
                  return isNaN(intentoFecha.getTime()) ? valorOriginal : intentoFecha;
                }
                
                return valorOriginal;
              });

              if (mapaRegistros.has(reciboIdActual)) {
                let rowIndex = mapaRegistros.get(reciboIdActual);
                let filaExistente = datosExistentes[rowIndex];
                
                nuevaFila[indexEstado] = filaExistente[indexEstado];
                nuevaFila[indexUltima] = filaExistente[indexUltima];
                nuevaFila[indexNotas] = filaExistente[indexNotas];
                
                let hayCambios = false;
                let zonaHoraria = Session.getScriptTimeZone();
                
                for (let c = 0; c < cabecerasMaestras.length; c++) {
                  let nombreCol = String(cabecerasMaestras[c]).trim();
                  let colNormalizada = nombreCol.toLowerCase();
                  
                  if (colNormalizada.includes("diferencia de d") || colNormalizada.includes("diasiniciovigencia") || colNormalizada === "dias") {
                    continue; 
                  }
                  
                  const normalizar = (val) => {
                    if (val == null || val === "") return "";
                    if (val instanceof Date) return Utilities.formatDate(val, zonaHoraria, "yyyy-MM-dd");
                    let strVal = String(val).trim();
                    if (!isNaN(strVal) && strVal !== "") return Number(strVal).toString(); 
                    return strVal;
                  };

                  let valViejo = normalizar(filaExistente[c]);
                  let valNuevo = normalizar(nuevaFila[c]);
                  
                  if (valNuevo !== valViejo) {
                    hayCambios = true;
                    break; 
                  }
                }
                
          
                if (hayCambios) {
                    // ✨ Si el CRM mandó información nueva, borramos el "visto" de la IA
                    // para que Gemini vuelva a analizar el comentario actualizado.
                    if (indexStatusIA !== -1) {
                      nuevaFila[indexStatusIA] = ''; 
                    }
                    
                    filasAActualizar.set(reciboIdActual, { filaReal: rowIndex + 1, datos: nuevaFila });
                  }
                
              } else {
                nuevaFila[indexEstado] = 'Pendiente';
                nuevaFila[indexUltima] = '';
                nuevaFila[indexNotas] = '';
                nuevasFilasMap.set(reciboIdActual, nuevaFila);
              }
            }
          }
        }
      }
      DriveApp.getFileById(archivoTemporal.id).setTrashed(true);
      
      // MOVER EL ARCHIVO ORIGINAL AL HISTORIAL
      let carpetaHistorial = DriveApp.getFolderById(ID_CARPETA_HISTORIAL);
      archivo.moveTo(carpetaHistorial);
      console.log(`Archivo movido al historial: ${nombreArchivo}`);

    } catch (error) {
      console.error("Error al procesar el archivo " + nombreArchivo + ": " + error.message);
    }
  }
  // =========================================================================
  // ✨ 3.5 INFERENCIA DE RECIBOS CONCILIADOS
  // =========================================================================
  let conciliadosInferidos = 0;
  if (minFechaReporte && maxFechaReporte && recibosEntrantesSet.size > 0 && indexVigenciaMaestra !== -1) {
    console.log(`🔍 Buscando conciliados inferidos entre ${minFechaReporte.toDateString()} y ${maxFechaReporte.toDateString()}...`);
    
    for (let i = 1; i < datosExistentes.length; i++) {
      let fila = datosExistentes[i];
      let id = String(fila[indexReciboId]).trim();
      let estadoActual = String(fila[indexEstado] || "").trim();
      
      // Si ya está conciliado, cancelado o no tiene ID, lo ignoramos
      if (id === "" || estadoActual.toLowerCase() === "conciliado" || estadoActual.toLowerCase().includes("cancelado")) continue;
      
      let fechaVigencia = new Date(fila[indexVigenciaMaestra]);
      
      // Si la fecha de este recibo cae dentro de las fechas del reporte nuevo...
      if (!isNaN(fechaVigencia.getTime()) && fechaVigencia >= minFechaReporte && fechaVigencia <= maxFechaReporte) {
        
        // ... pero NO viene en el reporte nuevo, inferimos que ya se concilió
        if (!recibosEntrantesSet.has(id)) {
          let filaActualizada = [...fila]; // Clonamos la fila para no afectar otras lecturas
          filaActualizada[indexEstado] = "Conciliado";
          
          // Lo mandamos a la fila de actualizaciones maestras para que se inyecte en el paso 4
          filasAActualizar.set(id, { filaReal: i + 1, datos: filaActualizada });
          conciliadosInferidos++;
        }
      }
    }
    console.log(`✅ Se infirieron ${conciliadosInferidos} recibos como Conciliados.`);
  }

  // =========================================================================
  // 4. INYECCIÓN DE DATOS EN SHEETS
  // =========================================================================
  let conteoActualizaciones = 0;
  for (let [id, infoUpdate] of filasAActualizar) {
    hojaMaestra.getRange(infoUpdate.filaReal, 1, 1, cabecerasMaestras.length).setValues([infoUpdate.datos]);
    conteoActualizaciones++;
  }

  let arrayNuevasFilas = Array.from(nuevasFilasMap.values());
  if (arrayNuevasFilas.length > 0) {
    hojaMaestra.getRange(hojaMaestra.getLastRow() + 1, 1, arrayNuevasFilas.length, cabecerasMaestras.length).setValues(arrayNuevasFilas);
  }

  // =========================================================================
  // 5. CATÁLOGOS AVANZADOS Y RECOLECCIÓN PARA AUDITORÍA LOG
  // =========================================================================
  
  // A. ACTUALIZAR RAMOS
  let datosCatRamos = hojaCatRamos.getDataRange().getValues();
  let ramosExistentes = new Set();
  if (datosCatRamos.length > 1) {
    for (let i = 1; i < datosCatRamos.length; i++) {
      if (datosCatRamos[i][2]) ramosExistentes.add(String(datosCatRamos[i][2]).trim());
    }
  }
  let nuevosRamos = [];
  ramosProcesadosSet.forEach(r => {
    if (!ramosExistentes.has(r) && r !== "") nuevosRamos.push([r]);
  });
  if (nuevosRamos.length > 0) {
    let ur = hojaCatRamos.getLastRow() < 1 ? 1 : hojaCatRamos.getLastRow();
    hojaCatRamos.getRange(ur + 1, 3, nuevosRamos.length, 1).setValues(nuevosRamos);
  }

  // B. ACTUALIZAR VENDEDORES
  let datosV = hojaCatVendedores.getDataRange().getValues();
  let vendActuales = new Set();
  if (datosV.length > 1) {
    for (let i = 1; i < datosV.length; i++) {
      if (datosV[i][2]) vendActuales.add(String(datosV[i][2]).trim());
    }
  }
  let nuevosVend = [];
  vendedoresProcesadosSet.forEach(v => {
    if (!vendActuales.has(v) && v !== "") nuevosVend.push([v]);
  });
  if (nuevosVend.length > 0) {
    let uv = hojaCatVendedores.getLastRow() < 1 ? 1 : hojaCatVendedores.getLastRow();
    hojaCatVendedores.getRange(uv + 1, 3, nuevosVend.length, 1).setValues(nuevosVend);
  }

  // C. CONSTRUIR CATALOGO DE GRUPOS Y AUDITAR
  datosV = hojaCatVendedores.getDataRange().getValues(); 
  let gruposUnicos = new Set();
  let listaVendedoresAuditada = [];
  listaVendedoresAuditada.push([datosV[0][1] || "Vendedores_sin_grupo", datosV[0][2] || "Vendedores_existentes", datosV[0][3] || "Grupo"]);
  
  // Arreglos para el Log Final
  let vendedoresSinBaseLog = [];
  let vendedoresAmbosLog = [];
  let vendedoresSinGrupoLog = [];

  for (let i = 1; i < datosV.length; i++) {
     let vend = String(datosV[i][2]).trim();
     let grupoString = String(datosV[i][3] || "").trim();
     let sinGrupo = "";
     
     if (vend !== "") {
       if (grupoString === "") {
         sinGrupo = vend; 
         vendedoresSinGrupoLog.push(vend);
       } else {
         grupoString.split(",").forEach(p => {
           let g = p.trim();
           if (g !== "") gruposUnicos.add(g);
         });
       }

       // --- VALIDACIÓN DE REGLAS DE NEGOCIO (1Seguros/Promotoria) ---
       let grpLower = grupoString.toLowerCase();
       let tiene1Seg = grpLower.includes('1seguros');
       let tieneProm = grpLower.includes('promotoria');

       if (!tiene1Seg && !tieneProm) {
           vendedoresSinBaseLog.push(vend);
       } else if (tiene1Seg && tieneProm) {
           vendedoresAmbosLog.push(vend);
       }

       listaVendedoresAuditada.push([sinGrupo, vend, grupoString]);
     }
  }
  if(listaVendedoresAuditada.length > 1) {
     hojaCatVendedores.getRange(1, 2, listaVendedoresAuditada.length, 3).setValues(listaVendedoresAuditada);
  }

  // Escribir lista maestra de Grupos
  let arrGrupos = Array.from(gruposUnicos).map(g => [g]);
  hojaCatGrupos.getRange("B:C").clearContent();
  hojaCatGrupos.getRange("B1:C1").setValues([["Grupos_sin_asignar", "Grupos"]]);
  if (arrGrupos.length > 0) {
    hojaCatGrupos.getRange(2, 3, arrGrupos.length, 1).setValues(arrGrupos);
  }

  // D. AUDITORÍA CONTRA ASIGNACIONES
  let datosAsign = hojaAsignaciones.getDataRange().getValues();
  let ramosAsigGlobal = "";
  let gruposAsigGlobal = "";
  
  if (datosAsign.length > 1) {
    for (let i = 1; i < datosAsign.length; i++) {
      let rVis = String(datosAsign[i][2] || "").trim(); 
      let gVis = String(datosAsign[i][3] || "").trim(); 
      if (rVis.toUpperCase() !== "TODOS") ramosAsigGlobal += rVis + ",";
      if (gVis.toUpperCase() !== "TODOS") gruposAsigGlobal += gVis + ",";
    }
  }

  // Auditoría Ramos
  let datosCatR = hojaCatRamos.getDataRange().getValues();
  let listaRamosAuditada = [[datosCatR[0][1] || "Ramos_sin_asignar", datosCatR[0][2] || "Ramos_existentes"]];
  let ramosSinAsignarLog = [];
  
  for (let i = 1; i < datosCatR.length; i++) {
    let r = String(datosCatR[i][2]).trim();
    if (r !== "") {
      let falta = ramosAsigGlobal.includes(r) ? "" : r;
      listaRamosAuditada.push([falta, r]);
      if (falta !== "") ramosSinAsignarLog.push(falta);
    }
  }
  if(listaRamosAuditada.length > 1) hojaCatRamos.getRange(1, 2, listaRamosAuditada.length, 2).setValues(listaRamosAuditada);

  // Auditoría Grupos
  let listaGruposAuditada = [["Grupos_sin_asignar", "Grupos"]];
  let gruposSinAsignarLog = [];
  
  Array.from(gruposUnicos).forEach(g => {
     let falta = gruposAsigGlobal.includes(g) ? "" : g;
     listaGruposAuditada.push([falta, g]);
     if (falta !== "") gruposSinAsignarLog.push(falta);
  });
  if (listaGruposAuditada.length > 1) hojaCatGrupos.getRange(1, 2, listaGruposAuditada.length, 2).setValues(listaGruposAuditada);

  // =========================================================================
  // 6. REPORTE FINAL EN EL LOG
  // =========================================================================
  console.log(`\n========== REPORTE DE AUDITORÍA ==========`);
  
  if (vendedoresSinBaseLog.length > 0) {
    console.log(`🚨 ERROR: Vendedores sin '1seguros' ni 'Promotoria': \n   -> ${vendedoresSinBaseLog.join(", ")}`);
  }
  if (vendedoresAmbosLog.length > 0) {
    console.log(`⚠️ ADVERTENCIA: Vendedores asignados a AMBOS (1seguros y Promotoria) a la vez: \n   -> ${vendedoresAmbosLog.join(", ")}`);
  }
  if (vendedoresSinGrupoLog.length > 0) {
    console.log(`🔸 Vendedores sin ningún grupo asignado: \n   -> ${vendedoresSinGrupoLog.join(", ")}`);
    return "DETENER";
  }
  if (ramosSinAsignarLog.length > 0) {
    console.log(`🔸 Ramos en catálogo pero NO asignados a ningún asistente: \n   -> ${ramosSinAsignarLog.join(", ")}`);
  }
  if (gruposSinAsignarLog.length > 0) {
    console.log(`🔸 Grupos en catálogo pero NO asignados a ningún asistente: \n   -> ${gruposSinAsignarLog.join(", ")}`);
  }
  if (clavesHuerfanasJMV.size > 0) {
  console.log(`⚠️ ALERTA JMV: Vendedores de '1seguros' con Clave de Agente NUEVA que no está en el Catalogo_ClavesJMV (Agrégalas para evitar perder recibos): \n   -> ${Array.from(clavesHuerfanasJMV).join(" | ")}`);
  }
  
  console.log(`==========================================\n`);
  console.log(`PROCESO TERMINADO. Inyectados: ${arrayNuevasFilas.length}. Actualizados: ${conteoActualizaciones}. Catálogos al 100%.`);
}


function actualizarFestivosMexico() {
  // Conectamos con el archivo Cobranzapp usando su ID
  var idLibro = '1tgROOAnGSGyeG0di86dSy9VqZv8bWmneWZNtYV05dGA';
  var libro = SpreadsheetApp.openById(idLibro);
  
  // Buscamos la pestaña Festivos, si no existe, la crea
  var hoja = libro.getSheetByName('Festivos');
  if (!hoja) {
    hoja = libro.insertSheet('Festivos');
  }

  var anioActual = new Date().getFullYear();
  
  // Generamos los festivos de este año y del próximo para evitar errores en diciembre/enero
  var festivos = obtenerDiasFestivos(anioActual).concat(obtenerDiasFestivos(anioActual + 1));

  // Limpiamos la pestaña actual
  hoja.clear();
  
  // Escribimos los encabezados
  hoja.appendRow(['Fecha', 'Motivo', 'Tipo']);
