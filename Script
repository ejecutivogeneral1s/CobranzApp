      hoja.getRange(2,12,filas.length,1).setNumberFormat("$#,##0.00");
      
      let range = hoja.getRange(2,1,filas.length,cols.length);
      let rules = [];
      
      // A. Etiquetas de "Resuelto" (Pagado, Cancelado, Reexpedido)
      rules.push(SpreadsheetApp.newConditionalFormatRule()
        .whenFormulaSatisfied(`=OR(ISNUMBER(SEARCH("_pagad", $N2)), ISNUMBER(SEARCH("_aplicad", $N2)), ISNUMBER(SEARCH("_cancelad", $N2)), ISNUMBER(SEARCH("_pt", $N2)), ISNUMBER(SEARCH("_reexpedid", $N2)))`)
        .setFontColor("#999999").setBackground("#ffffff").setRanges([range]).build());

      // B. Etiquetas de "Trámite" (Espera y Promesa) con fondo blanco
      if (cEspera) rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied(`=ISNUMBER(SEARCH("_espera", $N2))`).setFontColor("#e69138").setBackground("#ffffff").setRanges([range]).build());
      if (cPromesa) rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied(`=ISNUMBER(SEARCH("promesa", $N2))`).setFontColor("#38761d").setBackground("#ffffff").setRanges([range]).build());
      
      // C. Colores de Urgencia
      if (coloreaReportes) {
        rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied(`=$A2<=-31`).setBackground("#f4cccc").setRanges([range]).build());
        rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied(`=AND($A2>=-30, $A2<=-1)`).setBackground("#fff2cc").setRanges([range]).build());
        rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied(`=$A2=0`).setFontColor("#741b47").setRanges([range]).build());
      }
      
      if (rules.length > 0) hoja.setConditionalFormatRules(rules);
    }
    
    hoja.autoResizeColumns(1, 13);
    hoja.hideColumns(14);
    SpreadsheetApp.flush();
    
    // 📂 DETERMINAR CARPETA DESTINO (Ruta Dinámica o Individual)
    let carpetaDestinoId = config.id; // Por defecto la individual del catálogo
    
    if (ubicacionGlobal !== "") {
      // Si B6 tiene un ID, calculamos la ruta Año\Mes\Día\Vendedor
      carpetaDestinoId = obtenerOCrearRutaDinamica(ubicacionGlobal, nombre);
    }
    
    // Movemos el archivo a la carpeta destino calculada
    DriveApp.getFileById(ssN.getId()).moveTo(DriveApp.getFolderById(carpetaDestinoId));

     // ✨ LOG RESTAURADO AQUÍ
    console.log(`ÉXITO: Reporte de ${nombre} generado en carpeta ID: ${carpetaDestinoId}`);

    if (enviarEmails && config.mail) {
      let blob = UrlFetchApp.fetch(`https://docs.google.com/spreadsheets/d/${ssN.getId()}/export?format=xlsx`, {headers:{Authorization:"Bearer "+ScriptApp.getOAuthToken()}}).getBlob().setName(`${prefijo} Cobranza ${nombre}.xlsx`);
      GmailApp.sendEmail(config.mail, `Reporte Cobranza: ${nombre}`, "Adjunto reporte actualizado.", {
      bcc: "promotoria@1seguros.mx", 
      attachments: [blob],
      from: "promotoria@1seguros.mx"
      });
    }
  }
  
  hojaConfig.getRange("B14").setValue(true);
  console.log("✅ Reportes Individuales finalizados con formatos correctos.");
}

