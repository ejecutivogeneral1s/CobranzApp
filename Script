    if (filasSubs && filasSubs.length > 0) {
      // Si es el primer ramo con datos, creamos el archivo maestro
      if (!tieneDatosSubs) {
        spreadsheetSubs = SpreadsheetApp.create(nombreArchivoSubs);
        tieneDatosSubs = true;
      }

      // Ordenamos por fecha
      filasSubs.sort((a, b) => (new Date(a[idxVigencia]).getTime() || 0) - (new Date(b[idxVigencia]).getTime() || 0));

      // Creamos una pestaña con el nombre del Ramo
      let nuevaHoja = isFirstSheetSubs ? spreadsheetSubs.getSheets()[0] : spreadsheetSubs.insertSheet();
      nuevaHoja.setName(reporteNombre);
      isFirstSheetSubs = false;

      // Preparamos la matriz de datos con las fórmulas de Días
      let matrizExportacion = [columnasDeseadas];
