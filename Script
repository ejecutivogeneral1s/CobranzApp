    }
  } else {
    console.log(`INFO: Hoy no hubo recibos para Conciliar Subs, no se generó el reporte consolidado.`);
  }
  
  // =========================================================================
  // 6. RESTAURACIÓN DE INTERRUPTORES (CLEANUP)
  // =========================================================================
  hojaConfig.getRange("B14").setValue(true); // Re-armar el seguro
  hojaConfig.getRange("B16").setValue(true);
  if (ubicacionALT !== "") {
