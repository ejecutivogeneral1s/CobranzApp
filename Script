        carpetaDestino = getOrCreateFolder(folderRamo, nombreCarpetaMes);
      }
      archivoDrive.moveTo(carpetaDestino);
    }
    console.log(`ÉXITO: Reporte [${nombreArchivoFinal}] creado.`);
    Utilities.sleep(3000); // 😴 Pausa de 3 segundos para que Google Sheets respire

    // =========================================================================
    // 5. ENVÍO DE CORREOS (Enlace a Google Sheets)
    // =========================================================================
    if (enviarEmails && cfg.emails !== "" && cfg.emails !== "undefined") {
      try {
