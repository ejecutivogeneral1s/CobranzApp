      }
    }
  }
// =========================================================================
  // 5.5 REPORTE CONSOLIDADO DE "CONCILIAR SUBS" PARA PROMOTORÍA
  // =========================================================================
  let tieneDatosSubs = false;
  let spreadsheetSubs = null;
  let isFirstSheetSubs = true;
  let nombreArchivoSubs = `${mm} ${dd} ${mesTexto} REPORTE CONCILIAR SUBS`;

  // Recorremos todos los ramos de nuevo, pero ahora solo sacamos la carnita de "Conciliar Subs"
  for (let cfg of configReportes) {
    let reporteNombre = cfg.nombre;
