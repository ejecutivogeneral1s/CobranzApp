/** MOTOR DE IA: ANALIZA COMENTARIOS Y DETECTA ETIQUETAS MÚLTIPLES
 * Procesa en lotes de 50, usa columna técnica de control y genera reporte con Ramo. */
function procesarComentariosIA() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const hojaMaestra = ss.getSheetByName('BD_Cobranza');
  
  // 1. CONFIGURACIÓN E ÍNDICES
  const API_KEY = PropertiesService.getScriptProperties().getProperty('GEMINI_API_KEY');
  const ID_CARPETA_REPORTE = "1GNj0BCfFjIDNj9ETpm5oZHMsWOrPj0cn"; 
  
  if (!API_KEY) return SpreadsheetApp.getUi().alert("❌ ERROR: Falta la API Key en Propiedades del Script.");
  if (!hojaMaestra) return SpreadsheetApp.getUi().alert("No se encontró la hoja BD_Cobranza");

  const datos = hojaMaestra.getDataRange().getValues();
  const cabeceras = datos[0];
  
  // Mapeo dinámico de columnas
  const idxCliente = cabeceras.indexOf('Cliente');
  const idxPoliza = cabeceras.indexOf('Póliza');
  const idxRecibo = cabeceras.indexOf('Serie recibo');
  const idxConcepto = cabeceras.indexOf('Concepto');
  const idxComentario = cabeceras.indexOf('Comentario');
  const idxNotas = cabeceras.indexOf('Notas_Asistente');
  const idxStatusIA = cabeceras.indexOf('status_cobranzapp');
  const idxRamo = cabeceras.indexOf('Ramo');

  // =========================================================================
  // 2. RECOLECTAR SOLO LOS QUE NECESITAN ANÁLISIS Y PROCESAR POR LOTES
  // =========================================================================
  let lote = [];
  let cambiosParaReporte = [];
  let contadorModificados = 0;

  for (let i = 1; i < datos.length; i++) {
    let comentario = String(datos[i][idxComentario]).trim();
    if (comentario === "") continue;

    let notaAsistente = String(datos[i][idxNotas] || "").toLowerCase();
      let statusIA = (idxStatusIA !== -1) ? String(datos[i][idxStatusIA]).toLowerCase() : "";

      // ✨ Ahora también verificamos si el comentario original ya tiene una etiqueta para no procesarlo doble
      if (comentario.includes('_') || notaAsistente.includes('_') || statusIA === '_visto_ia') {
        continue;
      }

    lote.push({
      fila: i + 1,
      cliente: datos[i][idxCliente],
      poliza: datos[i][idxPoliza],
      ramo: datos[i][idxRamo],
      datosRecibo: datos[i][idxRecibo],
      datosConcepto: datos[i][idxConcepto],
      comentario: comentario
    });

    if (lote.length === 50 || i === datos.length - 1) {
      if (lote.length > 0) {
        console.log(`Procesando ${lote.length} comentarios (Extraídos entre la fila ${lote[0].fila} y la fila ${lote[lote.length-1].fila})...`);
        
        let respuestasGemini = llamarGeminiPorLote(lote, API_KEY);
        
        if (respuestasGemini && respuestasGemini.length === lote.length) {
          for (let j = 0; j < lote.length; j++) {
            let item = lote[j];
            let tagIA = String(respuestasGemini[j]).trim().toLowerCase();

            // ✨ AHORA VERIFICAMOS MÚLTIPLES ETIQUETAS (Puedes agregar más si lo necesitas)
            if (tagIA === "_pagado" || tagIA === "_cancelado" || tagIA === "_pt" || tagIA === "_reexpedido" || tagIA === "_espera" || tagIA === "_promesa") {
              
              // ✨ Concatenamos la etiqueta al final del comentario original y la guardamos en la columna Comentario
              let nuevoComentario = item.comentario + " " + tagIA;
              hojaMaestra.getRange(item.fila, idxComentario + 1).setValue(nuevoComentario);
              
              // Guardamos 7 datos para el reporte
              cambiosParaReporte.push([
                item.cliente, 
                item.poliza, 
                item.ramo, 
                item.datosRecibo, 
                item.datosConcepto, 
                item.comentario, 
                tagIA
              ]);
              contadorModificados++;
            } else {
              if (idxStatusIA !== -1) {
                hojaMaestra.getRange(item.fila, idxStatusIA + 1).setValue('_visto_ia');
              }
            }
          }
        } else {
                  // ✨ LOG EXPLÍCITO DE DIAGNÓSTICO
                  console.error("🛑 ERROR EN LOTE: La respuesta de Gemini no coincide con el lote o falló.");
                  console.error(`👉 Esperábamos ${lote.length} etiquetas de respuesta.`);
                  
                  if (respuestasGemini === null) {
                    console.error("👉 Gemini devolvió: NULL. (Revisa si hay un 'Error de API' en los logs anteriores).");
                  } else {
                    console.error(`👉 Gemini devolvió un arreglo con ${respuestasGemini.length} elementos.`);
                    console.error("👉 Contenido exacto devuelto por Gemini: " + JSON.stringify(respuestasGemini));
                  }
                }

                lote = [];
                Utilities.sleep(5000);
      }
    }
  }

  // =========================================================================
  // 4. GENERACIÓN DEL REPORTE FINAL EN DRIVE
  // =========================================================================
  if (cambiosParaReporte.length > 0) {
    let fechaActual = Utilities.formatDate(new Date(), "GMT-6", "yyyy-MM-dd HH:mm");
    let nombreArchivo = "Reporte_Analisis_Pagos_IA_" + fechaActual;
    
    let nuevoSS = SpreadsheetApp.create(nombreArchivo);
    let hojaReporte = nuevoSS.getSheets()[0];
    
    // Encabezados (7 columnas)
    let headersReporte = ["Nombre", "Póliza", "Ramo", "Recibo", "Descripción", "Comentario Original", "Resultado IA"];
    hojaReporte.getRange(1, 1, 1, 7).setValues([headersReporte]).setFontWeight("bold").setBackground("#d9ead3");
    
    // ✨ FIX DEL ERROR: Aseguramos que inyecte 7 columnas
    hojaReporte.getRange(2, 1, cambiosParaReporte.length, 7).setValues(cambiosParaReporte);
      hojaReporte.autoResizeColumns(1, 7);
      
      let file = DriveApp.getFileById(nuevoSS.getId());
      let carpetaReportes = DriveApp.getFolderById(ID_CARPETA_REPORTE);
      file.moveTo(carpetaReportes);
      
      console.log("✅ Reporte consolidado de cambios de IA guardado en Drive con éxito.");

      // 📧 ENVIAR ENLACE POR CORREO ELECTRÓNICO AL REMITENTE
      try {
        let emailUsuario = Session.getActiveUser().getEmail();
        let urlReporte = nuevoSS.getUrl();
        let asuntoEmail = `CobranzApp: Reporte de Análisis de Pagos Disponible`;
        let cuerpoEmail = `Hola,\n\nEl Motor de Inteligencia Artificial ha terminado de procesar el lote de pólizas.\n\nSe ha generado un nuevo reporte de análisis con las etiquetas detectadas. Puedes consultarlo directamente en el siguiente enlace de Google Sheets:\n${urlReporte}\n\nSaludos,\nSistema CobranzApp.`;
        
        if (emailUsuario) {
          GmailApp.sendEmail(emailUsuario, asuntoEmail, cuerpoEmail);
          console.log(`📩 Correo con enlace del reporte enviado con éxito a: ${emailUsuario}`);
        }
      } catch (errorCorreo) {
        console.error(`⚠️ No se pudo enviar el correo con el enlace: ${errorCorreo.message}`);
      }

    } else {
    console.log("🏁 PROCESO FINALIZADO. No se encontraron nuevos pagos para reportar.");
  }
}

/** Función auxiliar que pide a Gemini analizar en lote y devolver JSON estricto. Entiende el contexto de seguros y usa tus etiquetas reales. */
function llamarGeminiPorLote(lote, key) {
  // Cambiamos al modelo estándar que tiene 1,500 peticiones diarias gratis
  const url = "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=" + key;


  let promptText = `Actúa como un analista de cobranza de una agencia de seguros.
  Tu tarea es leer una lista de comentarios extraídos de un CRM (Quattro) y clasificar cada uno asignándole UNA de las siguientes etiquetas exactas:

  - "_pagado" : Si indica que se liquidó la totalidad del recibo o se aplicó el cobro.
  - "_promesa" : Si el cliente prometió pagar en una fecha futura específica.
  - "_cancelado" : Si la póliza o el recibo fue anulado o declinado definitivamente. incluye perdidas totales (PT)
  - "_reexpedido" : Si el recibo o poliza ya no es valido por reexpedición.
  - "PENDIENTE" : Si el texto está vacío o no da indicios claros de ninguna de las anteriores.

  REGLA ESTRICTA Y CRÍTICA: Devuelve ÚNICAMENTE un arreglo JSON válido. Sin formato markdown, sin tildes, sin explicaciones.
  ⚠️ IMPORTANTE: Recibirás exactamente ${lote.length} comentarios. Tu arreglo de respuesta DEBE contener EXACTAMENTE ${lote.length} elementos, manteniendo el mismo orden. NO OMITAS NINGUNO.
  Ejemplo de salida esperada: ["_pagado", "PENDIENTE", "_promesa"]

  Comentarios a analizar:\n`;

  lote.forEach((item, index) => {
    promptText += `[${index}] Texto: "${item.comentario}"\n`;
  });
  
  const payload = { 
    "contents": [{ "parts": [{ "text": promptText }] }], 
    "generationConfig": {
        "temperature": 0.0,
        "responseMimeType": "application/json" // 🚀 MAGIA DE VIBECODING: Esto obliga a Gemini a responder JSON perfecto
    } 
  };
  
  const options = { 
    "method": "post", 
    "contentType": "application/json", 
    "payload": JSON.stringify(payload), 
    "muteHttpExceptions": true 
  };

  try {
    const response = UrlFetchApp.fetch(url, options);
    if (response.getResponseCode() !== 200) {
      console.error("Error de API: " + response.getContentText());
      return null;
    }
    
    // Al usar responseMimeType, el parseo es casi 100% seguro
    const resText = JSON.parse(response.getContentText());
    let textoCrudo = resText.candidates[0].content.parts[0].text;
    
    return JSON.parse(textoCrudo);

  } catch (error) {
    console.error("Fallo general en la llamada a Gemini: " + error.message);
    return null;
  }
}


/** Función huerfana para descubrir los modelos disponibles de Gemini.  */
function descubrirMisModelos() {
  // 🔴 PEGA TU LLAVE AQUÍ
  const API_KEY = PropertiesService.getScriptProperties().getProperty('GEMINI_API_KEY');
  
  
  const url = "https://generativelanguage.googleapis.com/v1beta/models?key=" + API_KEY;
  const options = { "method": "get", "muteHttpExceptions": true };
  
  const response = UrlFetchApp.fetch(url, options);
  const json = JSON.parse(response.getContentText());
  
  if (json.models) {
    console.log("✅ MODELOS DISPONIBLES PARA GENERAR TEXTO:");
    json.models.forEach(m => {
      // Filtramos solo los que sirven para leer y generar texto
      if (m.supportedGenerationMethods && m.supportedGenerationMethods.includes("generateContent")) {
        console.log("👉 " + m.name);
      }
    });
  } else {
    console.log("❌ Error leyendo modelos: " + response.getContentText());
  }
}

