  const varsCancelado = ['_cancelado', '_cancelada', '_pt'];
  const varsReexpedido = ['_reexpedido', '_reexpedida'];
  const dict = new Map();

  for (let i = 1; i < datos.length; i++) {
    let fila = datos[i];
    
    // ✨ ESCUDO PROTECTOR INFALIBLE
    let estadoCobranza = String(fila[idxEstado] || "").trim().toLowerCase();
    if (estadoCobranza === "conciliado") {
      continue;
    }

    // 🛡️ FILTRO DE GRUPO PROMOTORÍA
    if (!String(fila[idxGrupo]).toLowerCase().includes('promotoria')) {
      continue;
    }

    let vend = String(fila[idxVendedor]).trim();
    let texto = (String(fila[idxCom]) + " " + String(fila[idxNot])).toLowerCase();

    // ❌ Filtros de visualización (Sin el fPagado que tronaba)
    if (
      (!fCancelado && varsCancelado.some(v => texto.includes(v))) ||
      (!fReexpedido && varsReexpedido.some(v => texto.includes(v))) ||
      (!fCat && texto.includes('_cat')) ||
      (!fIgnorar && texto.includes('_ignorar'))
    ) {
      continue;
    }

    let fVig = new Date(fila[idxVigencia]);
    let fCorte = new Date(); 
    fCorte.setDate(fCorte.getDate() - diasVista);
    
    if (fVig < fCorte) {
      continue;
    }

    if (!dict.has(vend)) dict.set(vend, []);
    dict.get(vend).push(fila);
  }

  // Generación
  const cols = ["Diferencia de días", "Cliente", "Póliza", "Aseguradora", "Serie recibo", "Total de recibos", "Forma de Pago", "Ramo", "Vigencia inicial recibo", "Vigencia final recibo", "Conducto", "Total", "Concepto", "Comentario"];
  const idxs = cols.map(c => cab.indexOf(c));
  let prefijo = Utilities.formatDate(new Date(), "GMT-6", "yyMMMMMdd").toUpperCase();

  for (let [nombre, filas] of dict) {
    if (!mapaConfig.has(nombre)) continue;
    filas.sort((a,b) => new Date(a[idxVigencia]) - new Date(b[idxVigencia]));
    let matriz = [cols];
    
    filas.forEach((f, r) => {
      let n = idxs.map(idx => idx !== -1 ? f[idx] : "");
      n[0] = `=ROUNDUP(I${r+2}-TODAY(), 0)`;
      if (idxNot !== -1 && f[idxNot]) n[13] = (n[13] ? n[13] + " | " : "") + String(f[idxNot]);
