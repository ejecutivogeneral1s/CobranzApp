  console.log(`PROCESO JMV FINALIZADO CORRECTAMENTE.`);
}

/** Crea o busca una ruta de carpetas dinámicas basadas en la fecha actual y el vendedor.
 * Ruta: CarpetaRaíz / Año / MM Mes / DD Mes / Vendedor
 */
function obtenerOCrearRutaDinamica(folderRaizId, nombreVendedor) {
  let carpetaActual = DriveApp.getFolderById(folderRaizId);
  const fecha = new Date();
  
  // 1. Array de meses en español para los nombres de carpetas
  const meses = [
    "01 Enero", "02 Febrero", "03 Marzo", "04 Abril", "05 Mayo", "06 Junio",
    "07 Julio", "08 Agosto", "09 Septiembre", "10 Octubre", "11 Noviembre", "12 Diciembre"
  ];
  
  // 2. Obtener valores de fecha
  const anioStr = fecha.getFullYear().toString();                       // "2026"
  const mesStr = meses[fecha.getMonth()];                               // "05 Mayo"
  const diaStr = `${fecha.getDate().toString().padStart(2, '0')} ${mesStr.split(' ')[1]}`; // "20 Mayo"
  
  // 3. Estructura de niveles a verificar/crear
  const niveles = [anioStr, mesStr, diaStr, nombreVendedor.trim()];
  
  // 4. Ciclo ninja que navega o crea nivel por nivel
  for (let i = 0; i < niveles.length; i++) {
    let nombreNivel = niveles[i];
    let subCarpetas = carpetaActual.getFoldersByName(nombreNivel);
    
    if (subCarpetas.hasNext()) {
      carpetaActual = subCarpetas.next(); // Si ya existe, nos metemos a ella
    } else {
      carpetaActual = carpetaActual.createFolder(nombreNivel); // Si no existe, la crea y nos metemos
    }
  }
  
  return carpetaActual.getId(); // Regresa el ID de la carpeta final (la del vendedor)
}

/** Crea o busca una ruta de carpetas dinámicas basadas en la fecha actual para el Reporte Global.
 * Ruta: CarpetaRaíz / Año / MM Mes / DD Mes
 */
function obtenerOCrearRutaGlobalDinamica(folderRaizId) {
  let carpetaActual = DriveApp.getFolderById(folderRaizId);
  const fecha = new Date();

  // Array de meses en español
  const meses = [
    "01 Enero", "02 Febrero", "03 Marzo", "04 Abril", "05 Mayo", "06 Junio",
    "07 Julio", "08 Agosto", "09 Septiembre", "10 Octubre", "11 Noviembre", "12 Diciembre"
  ];

  // Obtener valores de fecha
  const anioStr = fecha.getFullYear().toString();
  const mesStr = meses[fecha.getMonth()];
  const diaStr = `${fecha.getDate().toString().padStart(2, '0')} ${mesStr.split(' ')[1]}`;

  // Estructura de niveles: Año -> Mes -> Día (sin vendedor)
  const niveles = [anioStr, mesStr, diaStr];

  for (let i = 0; i < niveles.length; i++) {
    let nombreNivel = niveles[i];
    let subCarpetas = carpetaActual.getFoldersByName(nombreNivel);

    if (subCarpetas.hasNext()) {
      carpetaActual = subCarpetas.next();
    } else {
      carpetaActual = carpetaActual.createFolder(nombreNivel);
    }
  }

  return carpetaActual.getId(); // Regresa el ID de la carpeta del Día
}

