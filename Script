      nuevaHoja.setName(tabName);
      isFirstSheet = false;

      let matrizExportacion = [columnasDeseadas];
      for (let r = 0; r < filas.length; r++) {
        let filaCruda = filas[r];
        let filaNueva = indicesDeseados.map(idx => idx !== -1 ? filaCruda[idx] : "");
        
        filaNueva[0] = `=DAYS($L${r + 2}, TODAY())`;
        filaNueva[15] = `=DAYS($L${r + 2}, TODAY())`; 

        // ✨ Unificamos la nota de la IA en la columna de Comentarios (Índice 21) para el Formato Condicional
        if (idxNotas !== -1 && filaCruda[idxNotas]) {
          let notaOriginal = filaNueva[21] ? filaNueva[21] + " | " : "";
          filaNueva[21] = notaOriginal + String(filaCruda[idxNotas]);
        }
        
        matrizExportacion.push(filaNueva);
      }

      nuevaHoja.getRange(1, 1, matrizExportacion.length, columnasDeseadas.length).setValues(matrizExportacion);
      nuevaHoja.getRange(1, 1, 1, columnasDeseadas.length).setFontWeight("bold").setBackground("#e0e0e0");

      let numFilas = filas.length;
      nuevaHoja.getRange(2, 1, numFilas, 1).setNumberFormat("0");
      nuevaHoja.getRange(2, 16, numFilas, 1).setNumberFormat("0");
      nuevaHoja.getRange(2, 12, numFilas, 3).setNumberFormat("yyyy-MM-dd");
      nuevaHoja.getRange(2, 23, numFilas, 1).setNumberFormat("yyyy-MM-dd"); 
      nuevaHoja.getRange(2, 15, numFilas, 1).setNumberFormat("$#,##0.00"); 

      // ✨ FORMATO CONDICIONAL PERFECCIONADO
      let rules = [];
      let rangoCompleto = nuevaHoja.getRange(2, 1, numFilas, columnasDeseadas.length);
      let rangoVendedor = nuevaHoja.getRange(2, 21, numFilas, 1);
      let rangoNotas = nuevaHoja.getRange(2, 24, numFilas, 1);

      // El rojo de "(D)" aplica SOLO a la celda del vendedor
      rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied(`=ISNUMBER(SEARCH("(D)", $U2))`).setBackground("#f4cccc").setRanges([rangoVendedor]).build());
      // Negritas en Notas_Asistente
      rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied(`=AND($X2<>"", $X2<>$V2)`).setBold(true).setRanges([rangoNotas]).build());
      
      /* fragmento remplazado para mejorar formateo de de filas
       Prioridad de etiquetas manuales o de IA en la fila completa
      rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied(`=ISNUMBER(SEARCH("_espera", $V2))`).setFontColor("#e69138").setBackground("#ffffff").setRanges([rangoCompleto]).build());
      rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied(`=ISNUMBER(SEARCH("promesa", $V2))`).setFontColor("#38761d").setBackground("#ffffff").setRanges([rangoCompleto]).build());
      
      // ✨ Colores de Diferencia de días APLICADOS A TODA LA FILA (como en Promotoría)
      rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied(`=$A2<=-31`).setBackground("#f4cccc").setRanges([rangoCompleto]).build());
      rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied(`=AND($A2>=-30, $A2<=-1)`).setBackground("#fff2cc").setRanges([rangoCompleto]).build());
      rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied(`=$A2=0`).setFontColor("#741b47").setRanges([rangoCompleto]).build());

      nuevaHoja.setConditionalFormatRules(rules);
      nuevaHoja.autoResizeColumns(1, 24);
      nuevaHoja.hideColumns(22); // Ocultar Comentario Original (Columna V)*/

        // =========================================================================
        // ✨ PIRÁMIDE DE REGLAS DE FORMATO CONDICIONAL
        // =========================================================================

        // 1. REGLA MAESTRA: Si hay MÁS de 1 etiqueta -> Eliminar formato (Letra negra, fondo blanco)
        // Fórmula Larga Inactiva (con Notas_Asistente $X2): let fMasterLarga = `=(--OR(ISNUMBER(SEARCH("_pagad",$V2)),ISNUMBER(SEARCH("_aplicad",$V2)),ISNUMBER(SEARCH("_pagad",$X2)),ISNUMBER(SEARCH("_aplicad",$X2))) + --OR(ISNUMBER(SEARCH("promesa",$V2)),ISNUMBER(SEARCH("promesa",$X2))) + --OR(ISNUMBER(SEARCH("_cat",$V2)),ISNUMBER(SEARCH("_cat",$X2))) + --OR(ISNUMBER(SEARCH("_cancelad",$V2)),ISNUMBER(SEARCH("_reexpedid",$V2)),ISNUMBER(SEARCH("_pt",$V2)),ISNUMBER(SEARCH("_cancelad",$X2)),ISNUMBER(SEARCH("_reexpedid",$X2)),ISNUMBER(SEARCH("_pt",$X2))) + --OR(ISNUMBER(SEARCH("_espera",$V2)),ISNUMBER(SEARCH("_espera",$X2)))) > 1`;
        let formulaMaster = `=(--OR(ISNUMBER(SEARCH("_pagad",$V2)),ISNUMBER(SEARCH("_aplicad",$V2))) + --ISNUMBER(SEARCH("promesa",$V2)) + --ISNUMBER(SEARCH("_cat",$V2)) + --OR(ISNUMBER(SEARCH("_cancelad",$V2)),ISNUMBER(SEARCH("_reexpedid",$V2)),ISNUMBER(SEARCH("_pt",$V2))) + --ISNUMBER(SEARCH("_espera",$V2))) > 1`;
        rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied(formulaMaster).setFontColor("#000000").setBackground("#ffffff").setRanges([rangoCompleto]).build());

        // 2. PROMESA -> Fondo Light Blue 3 (#cfe2f3)
        rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied(`=ISNUMBER(SEARCH("promesa", $V2))`).setFontColor("#000000").setBackground("#cfe2f3").setRanges([rangoCompleto]).build());

        // 3. PAGADO / APLICADO -> Fondo Light Green (#d9ead3) (Excluyendo pestañas de Conciliar)
        if (!tabName.includes("Conciliar")) {
          // Fórmula Larga Inactiva: let fPagadoLarga = `=OR(ISNUMBER(SEARCH("_pagad", $V2)), ISNUMBER(SEARCH("_aplicad", $V2)), ISNUMBER(SEARCH("_pagad", $X2)), ISNUMBER(SEARCH("_aplicad", $X2)))`;
          let formulaPagado = `=OR(ISNUMBER(SEARCH("_pagad", $V2)), ISNUMBER(SEARCH("_aplicad", $V2)))`;
          rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied(formulaPagado).setFontColor("#000000").setBackground("#d9ead3").setRanges([rangoCompleto]).build());
        }

        // 4. CAT -> Fondo Light Cyan (#e0ffff)
        rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied(`=ISNUMBER(SEARCH("_cat", $V2))`).setFontColor("#000000").setBackground("#e0ffff").setRanges([rangoCompleto]).build());

        // 5. BLOQUE CANCELADOS (_cancelado, _reexpedido, _pt) -> Letra Roja Viva combinada con Fondos de Atraso
        let baseCancelado = `OR(ISNUMBER(SEARCH("_cancelad", $V2)), ISNUMBER(SEARCH("_reexpedid", $V2)), ISNUMBER(SEARCH("_pt", $V2)))`;
        // Combo A: <= -31 días (Fondo Rojo Claro)
        rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied(`=AND(${baseCancelado}, $A2<=-31)`).setFontColor("#ff0000").setBackground("#f4cccc").setRanges([rangoCompleto]).build());
        // Combo B: -30 a -1 días (Fondo Amarillo)
        rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied(`=AND(${baseCancelado}, $A2>=-30, $A2<=-1)`).setFontColor("#ff0000").setBackground("#fff2cc").setRanges([rangoCompleto]).build());
        // Combo C: Demás casos (0 días o sin atraso - Fondo Blanco)
        rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied(`=${baseCancelado}`).setFontColor("#ff0000").setBackground("#ffffff").setRanges([rangoCompleto]).build());

        // 6. ESPERA -> Texto Naranja, Fondo Blanco (Ignora días de atraso)
        rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied(`=ISNUMBER(SEARCH("_espera", $V2))`).setFontColor("#e69138").setBackground("#ffffff").setRanges([rangoCompleto]).build());

        // 7. DÍAS DE ATRASO PUROS (Aplica si no hay ninguna etiqueta superior)
        rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied(`=$A2<=-31`).setBackground("#f4cccc").setRanges([rangoCompleto]).build());
        rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied(`=AND($A2>=-30, $A2<=-1)`).setBackground("#fff2cc").setRanges([rangoCompleto]).build());
        rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied(`=$A2=0`).setFontColor("#741b47").setRanges([rangoCompleto]).build());

        nuevaHoja.setConditionalFormatRules(rules);
        nuevaHoja.autoResizeColumns(1, 24);
        
        // ✨ Visibilidad de Columnas Modificada:
        // Se mantiene visible la columna 22 (Comentario original)
        nuevaHoja.hideColumns(23); // Oculta Fecha Bitacora (Columna W)
        nuevaHoja.hideColumns(24); // Oculta Notas_Asistente (Columna X)

    }

    SpreadsheetApp.flush();
    if (baseFolder) {
      let archivoDrive = DriveApp.getFileById(idArchivo);
      let carpetaDestino = null;
      if (ubicacionALT !== "") {
        carpetaDestino = baseFolder;
      } else {
        let folderYear = getOrCreateFolder(baseFolder, aa);
        let folderRep = getOrCreateFolder(folderYear, "REPORTES COBRANZA");
