  }

  // =========================================================================
  // 4. CREACIÓN DE ARCHIVOS Y FORMATO CONDICIONAL (Estilo Promotoría)
  // =========================================================================
  for (let cfg of configReportes) {
    let reporteNombre = cfg.nombre;
