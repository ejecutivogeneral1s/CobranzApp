      fila[encabezados[j]] = datosBD[i][j];
    }
    fila.indiceFila = i + 1; 
    baseCobranza.push(fila);
  }

  // 3. Crear/Obtener Etiquetas 
  var etiquetaSeguimiento = obtenerOCrearEtiqueta("Seguimiento_Enviado");
  var etiquetaPagado = obtenerOCrearEtiqueta("Pagado");
  var etiquetaMensual = obtenerOCrearEtiqueta("Mensual");
  var etiquetaError = obtenerOCrearEtiqueta("Error_BD"); // Instanciamos la etiqueta de error al inicio

  // 4. Búsqueda ultra filtrada (Incluye ambas variantes de asunto)
  var busqueda = '(subject:"// POLIZA GMM" OR subject:"// HEALTH INSURANCE") from:me -label:Seguimiento_Enviado -label:Pagado -label:Mensual -label:Error_BD newer_than:40d';
  var hilos = GmailApp.search(busqueda);
  var miCorreo = Session.getActiveUser().getEmail();
  var hoy = new Date();

  Logger.log("[INFO] Se encontraron " + hilos.length + " hilos pendientes de revisión en Gmail.");

  // 5. Procesar cada correo
  for (var h = 0; h < hilos.length; h++) {
    var hilo = hilos[h];
    var asunto = hilo.getFirstMessageSubject(); 
    var mensajes = hilo.getMessages();
    var ultimoMensaje = mensajes[mensajes.length - 1];

    Logger.log(" "); 
    Logger.log("[INFO] --- Evaluando Hilo " + (h + 1) + " ---");

    // Validar si el cliente ya contestó
    var clienteYaRespondio = false;
    for (var m = 0; m < mensajes.length; m++) {
      if (mensajes[m].getFrom().indexOf(miCorreo) === -1) {
        clienteYaRespondio = true;
        break;
      }
    }

    if (clienteYaRespondio) {
      Logger.log('[OMITIDO] El cliente ya respondió a este correo. Asunto: "' + asunto + '"');
      if (!MODO_PRUEBA) {
        hilo.addLabel(etiquetaSeguimiento);
        Logger.log('[ETIQUETA] Se aplicó la etiqueta "Seguimiento_Enviado" para sacarlo del radar.');
      }
      continue; 
    }

    // -- PARSEO DEL ASUNTO --
    Logger.log('[LECTURA] Asunto original: "' + asunto + '"');
    var fragmentos = asunto.split("//");
    
    // ERROR BARRERA 1A: Faltan separadores
    if (fragmentos.length < 3) {
      Logger.log("[ERROR] Formato de asunto inválido (Faltan separadores //). Enviando alerta interna.");
      if (!MODO_PRUEBA) {
        var cuerpoErrorF = "<b>🚨 ALERTA DEL BOT DE COBRANZA</b><br><br>" +
                           "El asunto de este correo no tiene el formato correcto (faltan los separadores '//').<br><br>" +
                           "<b>Asunto detectado:</b> " + asunto + "<br><br>" +
                           "Por favor, asegúrate de estructurar el asunto correctamente.<br><br>" +
                           "<i>Nota: A este hilo se le ha puesto la etiqueta oculta 'Error_BD' para evitar reenviar esta alerta. Quítala cuando corrijas el error.</i>";
        ultimoMensaje.forward(miCorreo, { htmlBody: cuerpoErrorF });
        hilo.addLabel(etiquetaError);
        Logger.log('[ETIQUETA] Se aplicó la etiqueta "Error_BD" para no repetir la alerta de este hilo.');
      }
      continue; 
    }

    var segmentoPolizaBruto = fragmentos[1].trim(); 
    var segmentoPoliza = segmentoPolizaBruto.split("&")[0].trim().toUpperCase(); 
    var segmentoAseguradora = (fragmentos.length > 3) ? fragmentos[2].trim().toUpperCase() : fragmentos[1].trim().toUpperCase();
    var segmentoRecibo = fragmentos[fragmentos.length - 1].trim(); 

    var numeroReciboMatch = segmentoRecibo.match(/\d+/);
    var numeroRecibo = numeroReciboMatch ? parseInt(numeroReciboMatch[0]) : null;

    Logger.log('[DATOS EXTRAÍDOS] Póliza: "' + segmentoPoliza + '" | Aseguradora: "' + segmentoAseguradora + '" | Recibo: ' + (numeroRecibo !== null ? numeroRecibo : "NULL"));

    // ERROR BARRERA 1B: No se detectó un número de recibo
    if (!numeroRecibo) {
      Logger.log("[ERROR] No se detectó un número de recibo válido en el asunto. Enviando alerta interna.");
      if (!MODO_PRUEBA) {
        var cuerpoErrorR = "<b>🚨 ALERTA DEL BOT DE COBRANZA</b><br><br>" +
                           "No se detectó un número de recibo válido (dígito numérico) en el asunto del correo.<br><br>" +
                           "<b>Asunto detectado:</b> " + asunto + "<br>" +
                           "<b>Fragmento analizado:</b> " + segmentoRecibo + "<br><br>" +
                           "Recuerda usar números (ej. '2' en lugar de 'SECOND').<br><br>" +
                           "<i>Nota: A este hilo se le ha puesto la etiqueta oculta 'Error_BD' para evitar reenviar esta alerta. Quítala cuando corrijas el error.</i>";
        ultimoMensaje.forward(miCorreo, { htmlBody: cuerpoErrorR });
        hilo.addLabel(etiquetaError);
        Logger.log('[ETIQUETA] Se aplicó la etiqueta "Error_BD" para no repetir la alerta de este hilo.');
      }
      continue; 
    }

    // -- BÚSQUEDA EN BD (Triple Validación) --
    Logger.log("[BUSCANDO] Intentando match en BD_Cobranza...");
    
    var registroEncontrado = baseCobranza.find(function(registro) {
      var ramo = String(registro['Ramo'] || '').toUpperCase();
      var polizaHoja = String(registro['Póliza'] || '').toUpperCase();
      var aseguradoraHoja = String(registro['Aseguradora'] || '').toUpperCase();
      var reciboHoja = parseInt(registro['Serie recibo']);

      var matchRamo = (ramo === 'SALUD' || ramo === 'SALUD GPO');
      var matchPoliza = (polizaHoja.indexOf(segmentoPoliza) !== -1 || segmentoPolizaBruto.toUpperCase().indexOf(polizaHoja) !== -1);
      var matchAseguradora = (segmentoAseguradora.indexOf(aseguradoraHoja) !== -1 || asunto.toUpperCase().indexOf(aseguradoraHoja) !== -1);
      var matchRecibo = (reciboHoja === numeroRecibo);

      return matchRamo && matchPoliza && matchAseguradora && matchRecibo;
    });

    // ERROR BARRERA 2: No hubo coincidencia en Excel
    if (!registroEncontrado) {
      Logger.log("[ERROR] No se encontró coincidencia exacta en la BD. Enviando aviso interno.");
      
      if (!MODO_PRUEBA) {
        var cuerpoErrorBD = "<b>🚨 ALERTA DEL BOT DE COBRANZA</b><br><br>" +
                          "No se encontró una coincidencia exacta en la base de datos para este correo.<br><br>" +
                          "<b>Datos extraídos del asunto:</b><br>" +
                          "<ul>" +
                          "<li><b>Póliza buscada:</b> " + segmentoPoliza + "</li>" +
                          "<li><b>Aseguradora buscada:</b> " + segmentoAseguradora + "</li>" +
                          "<li><b>Recibo buscado:</b> " + numeroRecibo + "</li>" +
                          "</ul>" +
                          "Por favor, revisa que el asunto del correo y los datos en la pestaña <i>BD_Cobranza</i> coincidan exactamente.<br><br>" +
                          "<i>Nota: A este hilo se le ha puesto la etiqueta oculta 'Error_BD' para evitar reenviar esta alerta. Quítala cuando corrijas el error.</i>";
        
        ultimoMensaje.forward(miCorreo, { htmlBody: cuerpoErrorBD });
        hilo.addLabel(etiquetaError);
        Logger.log('[ETIQUETA] Se aplicó la etiqueta "Error_BD" para no repetir la alerta de este hilo.');
      }
      continue; 
    } 

    var estadoCobranza = String(registroEncontrado['Estado_Cobranza']).trim().toUpperCase();
    var formaPago = String(registroEncontrado['Forma de Pago']).trim().toUpperCase();
    var vigenciaInicial = new Date(registroEncontrado['Vigencia inicial recibo']);

    Logger.log("[EXITO] Cliente encontrado. Estado: " + estadoCobranza + " | Forma de pago: " + formaPago);

    // -- FLUJO DE DECISIÓN --
    if (estadoCobranza === 'CONCILIADO') {
      Logger.log("[OMITIDO] El estado es CONCILIADO.");
      if (!MODO_PRUEBA) {
        hilo.addLabel(etiquetaPagado);
        Logger.log('[ETIQUETA] Se aplicó la etiqueta "Pagado".');
      }
      continue;
    }

    if (formaPago === 'MENSUAL') {
      Logger.log("[OMITIDO] Pago MENSUAL. No se envía recordatorio automático.");
      if (!MODO_PRUEBA) {
        hilo.addLabel(etiquetaMensual);
        Logger.log('[ETIQUETA] Se aplicó la etiqueta "Mensual".');
      }
      continue;
    }

    if (estadoCobranza === 'PENDIENTE') {
      // 1. Validar Vigencia
      var fechaLimiteCobro = sumarDiasHabiles(vigenciaInicial, 4, festivos);
      fechaLimiteCobro.setHours(0,0,0,0);
      var hoySinHora = new Date();
      hoySinHora.setHours(0,0,0,0);

      if (hoySinHora <= fechaLimiteCobro) {
        var fechaFormatVigencia = fechaLimiteCobro.toISOString().split('T')[0];
        Logger.log("[EN ESPERA] Fecha límite calculada para vigencia: " + fechaFormatVigencia + ". Aún faltan días hábiles para el cobro.");
        continue;
      }

      // 2. Validar tiempo desde el último correo
      var fechaUltimoCorreo = new Date(ultimoMensaje.getDate());
      var fechaToleranciaCorreo = sumarDiasHabiles(fechaUltimoCorreo, 4, festivos);
      fechaToleranciaCorreo.setHours(0,0,0,0);

      if (hoySinHora >= fechaToleranciaCorreo) {
        
        if (MODO_PRUEBA) {
          Logger.log("[SIMULACIÓN] ✉️ Los tiempos se cumplieron. Aquí se habría enviado el correo.");
          Logger.log('[SIMULACIÓN] Se habría aplicado la etiqueta "Seguimiento_Enviado".');
        } else {
          // ACCIÓN REAL
          var htmlBody = ultimoMensaje.getBody(); 
          var adjuntos = ultimoMensaje.getAttachments(); 
          
          ultimoMensaje.replyAll("", {
            htmlBody: htmlBody,
            attachments: adjuntos
          });
          
          hilo.addLabel(etiquetaSeguimiento);
          Logger.log("[ACCIÓN] ✉️ Recordatorio enviado exitosamente.");
          Logger.log('[ETIQUETA] Se aplicó la etiqueta "Seguimiento_Enviado" tras enviar el recordatorio.');
        }

      } else {
        var fechaFormatSeguimiento = fechaToleranciaCorreo.toISOString().split('T')[0];
        Logger.log("[EN ESPERA] Fecha límite calculada para seguimiento: " + fechaFormatSeguimiento + ". Aún no se cumplen los 4 días hábiles de tolerancia.");
      }
    }
  }
  Logger.log("[INFO] Ejecución de Bot de COBRANZA Finalizada.");
}

// --- FUNCIONES AUXILIARES ---
function obtenerOCrearEtiqueta(nombre) {
  var etiqueta = GmailApp.getUserLabelByName(nombre);
  if (!etiqueta) {
    etiqueta = GmailApp.createLabel(nombre);
  }
  return etiqueta;
}

function sumarDiasHabiles(fechaInicio, diasASumar, festivosArreglo) {
  var fecha = new Date(fechaInicio.getTime());
  var diasSumados = 0;
  while (diasSumados < diasASumar) {
    fecha.setDate(fecha.getDate() + 1);
    var diaSemana = fecha.getDay();
    var fechaString = fecha.toISOString().split('T')[0];
    if (diaSemana !== 0 && diaSemana !== 6 && festivosArreglo.indexOf(fechaString) === -1) {
      diasSumados++;
    }
  }
  return fecha;
}







